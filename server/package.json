{
  "name": "industrial-tourism-server",
  "version": "1.0.0",
  "description": "Backend for Industrial Tourism Platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "init": "node init-data.js",
    "docker:build": "docker build -t industrial-tourism-server .",
    "docker:run": "docker run -p 5000:5000 -e NODE_ENV=production industrial-tourism-server",
    "docker:init": "docker exec industrial-tourism-server npm run init"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "express-session": "^1.17.3"
  }
}